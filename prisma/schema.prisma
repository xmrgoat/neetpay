generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Merchant {
  id             String   @id @default(cuid())
  email          String   @unique
  hashedPassword String
  webhookUrl     String?
  webhookSecret  String?
  xmrWalletAddress String?
  feePercent     Float    @default(0.4)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invoices    Invoice[]
  apiKeys     ApiKey[]
  webhookLogs WebhookLog[]
  branding    MerchantBranding?
}

model Invoice {
  id           String    @id @default(cuid())
  merchantId   String
  amountXmr    Float
  amountFiat   Float?
  fiatCurrency String?
  subaddress   String
  status       String    @default("pending") // pending | swap_pending | confirming | paid | expired | failed

  // Swap details (Wagyu or Trocador)
  swapProvider    String?  // "wagyu" | "trocador"
  swapOrderId     String?
  depositAddress  String?
  depositChain    String?
  depositToken    String?
  depositAmount   Float?

  // Transaction
  txHash        String?
  confirmations Int      @default(0)

  // Fee
  feePercent    Float?
  feeAmount     Float?
  netAmount     Float?

  // Merchant integration
  callbackUrl   String?
  returnUrl     String?
  metadata      Json?

  description   String?
  expiresAt     DateTime?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  merchant    Merchant     @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  webhookLogs WebhookLog[]

  @@index([merchantId])
  @@index([status])
  @@index([subaddress])
  @@index([swapOrderId])
  @@index([status, expiresAt])
}

model ApiKey {
  id        String    @id @default(cuid())
  merchantId String
  name      String    @default("Default")
  keyHash   String    @unique
  keyPrefix String
  expiresAt DateTime?
  lastUsed  DateTime?
  createdAt DateTime  @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
}

model WebhookLog {
  id         String    @id @default(cuid())
  merchantId String
  invoiceId  String?
  url        String
  payload    String
  statusCode Int
  success    Boolean
  attempts   Int       @default(0)
  nextRetryAt DateTime?
  createdAt  DateTime  @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  invoice  Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([merchantId])
  @@index([invoiceId])
  @@index([success, nextRetryAt])
}

model MerchantBranding {
  id           String   @id @default(cuid())
  merchantId   String   @unique
  logoUrl      String?
  brandName    String?
  primaryColor String?
  accentColor  String?
  customDomain String?  @unique
  hideNeetpay  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}
