# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database (docker-compose default)
DATABASE_URL="postgresql://voidpay:voidpay@localhost:5432/voidpay?schema=public"

# Auth.js v5
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Alchemy
ALCHEMY_API_KEY=
ALCHEMY_WEBHOOK_SIGNING_KEY=

# Seed encryption (AES-256-GCM)
SEED_ENCRYPTION_KEY=
ENCRYPTED_SEED=

# Dev only — use a test mnemonic (never in production)
# DEV_MNEMONIC="test test test test test test test test test test test junk"

# Bitcoin native node RPC (VPS bitcoind — falls back to Alchemy if empty)
BITCOIN_RPC_URL=
BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=

# Litecoin native node RPC (VPS litecoind)
LITECOIN_RPC_URL=http://localhost:9332
LITECOIN_RPC_USER=
LITECOIN_RPC_PASSWORD=

# Dogecoin native node RPC (VPS dogecoind)
DOGECOIN_RPC_URL=http://localhost:22555
DOGECOIN_RPC_USER=
DOGECOIN_RPC_PASSWORD=

# Monero wallet-rpc (docker-compose default)
MONERO_WALLET_RPC_URL=http://localhost:18082/json_rpc
MONERO_WALLET_RPC_USER=
MONERO_WALLET_RPC_PASSWORD=

# SideShift.ai swap
SIDESHIFT_SECRET=
SIDESHIFT_AFFILIATE_ID=

# THORChain (cross-chain swap)
THORCHAIN_NODE_URL=https://thornode.ninerealms.com
