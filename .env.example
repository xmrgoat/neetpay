# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080

# Database (shared between Rust backend and Prisma read-only)
DATABASE_URL="postgresql://neetpay:neetpay@localhost:5432/neetpay?schema=public"

# Magic link auth
RESEND_API_KEY=re_xxx
RESEND_FROM_ADDRESS=NeetPay <noreply@neetpay.com>
JWT_SECRET=xxx_minimum_32_chars_change_this_in_production
APP_URL=http://localhost:3000
MAGIC_LINK_EXPIRY_MINUTES=15
JWT_EXPIRY_DAYS=30

# Monero wallet-rpc
MONERO_WALLET_RPC_URL=http://localhost:18083/json_rpc
MONERO_WALLET_RPC_USER=
MONERO_WALLET_RPC_PASSWORD=

# Wagyu API (Arbitrum/Solana/BTC -> XMR swaps)
WAGYU_API_URL=https://api.wagyu.exchange
WAGYU_API_KEY=

# Trocador API (TRC20/BEP20/others -> XMR swaps)
TROCADOR_API_URL=https://trocador.app/api
TROCADOR_API_KEY=

# Redis (rate limiting, caching)
REDIS_URL=redis://localhost:6379

# Rust API server
API_PORT=8080
RUST_LOG=info
